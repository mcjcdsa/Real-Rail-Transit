{
	"schemaVersion": 1,
	"id": "real-rail-transit-mod",
	"version": "${version}",
	"name": "Real Rail Transit",
	"description": "高度还原真实轨道交通系统的专业级模组，提供完整的列车驾驶系统（六种驾驶模式）、信号联锁系统、调度运行图管理、车站设施、追加包支持（含MTR转换）、BB模型渲染等核心功能",
	"authors": [
		"Real Rail Transit 模组制作工作室"
	],
	"contact": {
		"homepage": "https://krtmod.github.io/real-railt-ransit.github.io/",
		"sources": "https://github.com/mcjcdsa/Real-Rail-Transit.git",
		"issues": "https://github.com/mcjcdsa/Real-Rail-Transit/issues",
		"email": "706025513@qq.com"
	},
	"license": "CC0-1.0",
	"icon": "assets/real-rail-transit-mod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.real.rail.transit.RealRailTransitMod"
		],
		"client": [
			"com.real.rail.transit.RealRailTransitModClient"
		],
		"fabric-datagen": [
			"com.real.rail.transit.RealRailTransitModDataGenerator"
		]
	},
	"mixins": [
		"real-rail-transit-mod.mixins.json",
		{
			"config": "real-rail-transit-mod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.20.6",
		"java": ">=21",
		"fabric-api": "*"
	}
}